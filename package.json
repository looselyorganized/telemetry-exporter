{
  "name": "lo-telemetry-exporter",
  "version": "0.1.0",
  "description": "Exports Claude Code telemetry to Supabase for the LO operations dashboard",
  "type": "module",
  "scripts": {
    "start": "bun run bin/daemon.ts",
    "backfill": "bun run bin/daemon.ts --backfill",
    "open": "bun run bin/lo-open.ts",
    "close": "bun run bin/lo-close.ts",
    "status": "bun run bin/lo-status.ts",
    "dashboard": "bun run bin/dashboard.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2"
  }
}
